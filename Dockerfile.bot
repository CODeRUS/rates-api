# Образ для Telegram-бота /rates (Telethon + те же зависимости, что у сводки).
FROM python:3.12-slim
WORKDIR /app

COPY requirements.txt requirements-bot.txt /tmp/
RUN pip install --no-cache-dir -r /tmp/requirements.txt -r /tmp/requirements-bot.txt \
    && rm -rf /tmp

COPY . /app

RUN mkdir -p /data/telethon /data/cache

ENV PYTHONUNBUFFERED=1
CMD ["python", "-m", "bot.main"]
