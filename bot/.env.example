# Положите в корень репозитория как `.env`: его подхватывают `rates.py`, `python -m bot.main` (см. env_loader)
# и docker compose (см. docker-compose.yml). Уже заданные в shell переменные не перезаписываются.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=

# Telegram user id администратора (число). Только он может /refresh — принудительно обновить кеш сводки.
# BOT_ADMIN_ID=

# Таймаут (сек) на один запуск сборки /rates или /usdt в фоне. По умолчанию 180.
# BOT_FETCH_TIMEOUT_SEC=180

# Опционально для Docker compose (см. docker-compose.yml):
# TELETHON_SESSION_DIR=/data/telethon
# RATES_CACHE_FILE=/data/cache/.rates_summary_cache.json
# RATES_USDT_CACHE_FILE=/data/cache/.rates_usdt_cache.json
# Повторы HTTP при обрывах (urllib / Bybit curl_cffi): RATES_HTTP_MAX_ATTEMPTS=4, RATES_HTTP_BACKOFF_BASE=0.5
#
# Chat-agent (FastAPI, 2×LLM + Redis): бот шлёт личку GPT-пользователей на POST …/chat
# CHAT_AGENT_URL=http://127.0.0.1:18880
# CHAT_AGENT_SHARED_SECRET=<тот же секрет, что у сервиса chat-agent>
# REDIS_URL=redis://127.0.0.1:6379/0  # у chat-agent
# CHAT_AGENT_LLM_PROVIDER=openai|google, OPENAI_* или GOOGLE_API_KEY/GEMINI_*
# CHAT_AGENT_PLANNER_USER_HISTORY_TURNS=0  # прошлые user-реплики для planner (0 = только текущее; для цепочек вроде «москва» → «доллар» нужен ≥1)
# Bangkok Bank GetLatestfxrates (проба: python3 scripts/bkb_probe_latestfxrates.py — см. докстринг скрипта)
# BANGKOKBANK_OCP_APIM_SUBSCRIPTION_KEY=
# Bangkok Bank: compose по умолчанию 240 с; клиент запроса — curl_cffi (браузерный TLS), если пакет есть.
# Принудительно urllib: BANGKOKBANK_HTTP_CLIENT=urllib
# Список impersonate через запятую: BANGKOKBANK_CURL_IMPERSONATE=chrome124,chrome131
# BANGKOKBANK_HTTP_TIMEOUT_SEC=240
# BANGKOKBANK_HTTP_MAX_ATTEMPTS=8
# BANGKOKBANK_HTTP_BACKOFF_BASE=1.0
# RATES_HTTP_MAX_ATTEMPTS=6
