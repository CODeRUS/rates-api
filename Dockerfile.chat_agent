# Образ chat-agent: нужен весь репозиторий (вызов rates.py --readonly из инструментов).
FROM python:3.12-slim
WORKDIR /app

COPY requirements.txt requirements-chat_agent.txt /tmp/
RUN pip install --no-cache-dir -r /tmp/requirements.txt -r /tmp/requirements-chat_agent.txt \
    && rm -rf /tmp

COPY . /app

ENV PYTHONUNBUFFERED=1
# Порт и хост — CHAT_AGENT_PORT / CHAT_AGENT_HOST из .env
CMD ["sh", "-c", "exec uvicorn chat_agent.app.main:app --host \"${CHAT_AGENT_HOST:-0.0.0.0}\" --port \"${CHAT_AGENT_PORT:-18880}\""]
